# Authentication
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-at-least-32-characters-long

# Google OAuth
# Get these from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Database (PostgreSQL required)
# For local development, use a local PostgreSQL instance or a free cloud provider
DATABASE_URL="postgresql://user:password@localhost:5432/psykasten?schema=public"

# Site URL (used for SEO canonical URLs, sitemap, and OG tags)
NEXT_PUBLIC_SITE_URL=https://psykasten.de

# Optional: Node Environment
NODE_ENV=development

# Optional: Upload Directory
UPLOAD_DIR=./uploads

# SMTP (Email verification)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@psykasten.de
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@psykasten.de

# Optional: Redis Rate Limiting (Upstash)
# For production, create a free account at https://upstash.com/
# Without these, the app will use in-memory rate limiting (not recommended for production)
# UPSTASH_REDIS_REST_URL=your-upstash-redis-url
# UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token
